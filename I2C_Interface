#include <FreeRTOS_ARM.h> // task.h, semphr.h 가 이미 포함됨
#include <Wire.h>

// 센서 I2C 주소 (I2C 스캐너 확인 결과)
#define HMC5883_ADDR 0x2C
#define MPU6050_ADDR 0x68

// 전방 선언
void readHMC5883();
void readMPU6050();

// 태스크 핸들
TaskHandle_t handle_hmc5883_task; // 지자기센서
TaskHandle_t handle_mpu6050_task; // 자이로 + 가속도 센서

// 뮤텍스 핸들
SemaphoreHandle_t i2cMutex;

// 센서 초기화
void initHMC5883() {
  // I2C PPT 12페이지 기준으로 작성
  // 전원 인가 후 Suspend Mode -> Continuous Mode로 전환

  // X,Y,Z 축 부호 정의를 통해 센서가 방향을 어떻게 해석할지 설정
  Wire.beginTransmission(HMC5883_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x29); // 버퍼에 레지스터 주소(29H) 올림
  Wire.write(0x06); // 버퍼에 데이터(0x06) 올림
  Wire.endTransmission(); // I2C 전송 시작

  // Set/Reset On, Field Range 8Gauss
  // Set/Reset: 센서 내부 소자 자화 방향 주기적 반전 → 온도/외부 충격 오차 자동 보정
  // Field Range 8Gauss: 측정 가능한 자기장 범위 설정
  Wire.beginTransmission(HMC5883_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x0B); // 버퍼에 레지스터 주소(0BH) 올림
  Wire.write(0x08); // 버퍼에 데이터(0x08) 올림
  Wire.endTransmission(); // I2C 전송 시작

  // Continuous Mode 전환 (전원 인가 시 기본값이 Suspend Mode라서 전환 필요)
  Wire.beginTransmission(HMC5883_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x0A); // 버퍼에 레지스터 주소(0AH) 올림
  Wire.write(0xC3); // 버퍼에 데이터(0xC3) 올림
  Wire.endTransmission(); // I2C 전송 시작
}

void initMPU6050() {
  // MPU6050은 전원 인가 시 기본값이 Sleep Mode
  // PWR_MGMT_1 레지스터(0x6B)에 0x00을 써서 Sleep Mode 해제

  Wire.beginTransmission(MPU6050_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x6B); // 버퍼에 레지스터 주소(PWR_MGMT_1) 올림
  Wire.write(0x00); // 버퍼에 데이터(0x00) 올림 → Sleep bit = 0, 모든 기능 활성화
  Wire.endTransmission(); // I2C 전송 시작
}


// 센서 읽기 함수
void readHMC5883() {
  uint8_t status;
  int16_t x, y, z;

  // Step 1: Status 레지스터(09H) 확인 → DRDY bit = 1이면 데이터 준비됨
  Wire.beginTransmission(HMC5883_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x09); // 버퍼에 레지스터 주소(09H) 올림
  Wire.endTransmission(false); // STOP 없이 전송 → Repeated START 준비

  Wire.requestFrom(HMC5883_ADDR, 1); // 1바이트 읽기 요청
  if (Wire.available()) {
    status = Wire.read(); // Status 바이트 읽기
  }

  // DRDY bit(bit0) = 1이면 데이터 준비됨
  if (status & 0x01) {
    // Step 2: 데이터 레지스터 01H ~ 06H 읽기 (6바이트)
    Wire.beginTransmission(HMC5883_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
    Wire.write(0x01); // 버퍼에 시작 레지스터 주소(01H) 올림
    Wire.endTransmission(false); // STOP 없이 전송 → Repeated START 준비

    Wire.requestFrom(HMC5883_ADDR, 6); // 6바이트 읽기 요청
    if (Wire.available() == 6) {
      uint8_t xLSB = Wire.read(); // 01H : X LSB
      uint8_t xMSB = Wire.read(); // 02H : X MSB
      uint8_t yLSB = Wire.read(); // 03H : Y LSB
      uint8_t yMSB = Wire.read(); // 04H : Y MSB
      uint8_t zLSB = Wire.read(); // 05H : Z LSB
      uint8_t zMSB = Wire.read(); // 06H : Z MSB

      // MSB << 8 | LSB 로 16bit 값 조합
      x = (int16_t)(xMSB << 8 | xLSB);
      y = (int16_t)(yMSB << 8 | yLSB);
      z = (int16_t)(zMSB << 8 | zLSB);

      Serial.print("HMC5883 X: "); Serial.print(x);
      Serial.print(" Y: "); Serial.print(y);
      Serial.print(" Z: "); Serial.println(z);
    }
  }
}

void readMPU6050() {
  int16_t accX, accY, accZ;
  int16_t gyroX, gyroY, gyroZ;

  // 가속도 읽기 (시작 레지스터 3BH부터 6바이트 연속 읽기)
  Wire.beginTransmission(MPU6050_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x3B); // 버퍼에 시작 레지스터 주소(3BH) 올림
  Wire.endTransmission(false); // STOP 없이 전송 → Repeated START 준비

  Wire.requestFrom(MPU6050_ADDR, 6); // 6바이트 읽기 요청
  if (Wire.available() == 6) {
    uint8_t axMSB = Wire.read(); // 3BH : 가속도 X MSB
    uint8_t axLSB = Wire.read(); // 3CH : 가속도 X LSB
    uint8_t ayMSB = Wire.read(); // 3DH : 가속도 Y MSB
    uint8_t ayLSB = Wire.read(); // 3EH : 가속도 Y LSB
    uint8_t azMSB = Wire.read(); // 3FH : 가속도 Z MSB
    uint8_t azLSB = Wire.read(); // 40H : 가속도 Z LSB

    // MSB << 8 | LSB 로 16bit 값 조합
    accX = (int16_t)(axMSB << 8 | axLSB);
    accY = (int16_t)(ayMSB << 8 | ayLSB);
    accZ = (int16_t)(azMSB << 8 | azLSB);

    Serial.print("MPU6050 Acc X: "); Serial.print(accX);
    Serial.print(" Y: "); Serial.print(accY);
    Serial.print(" Z: "); Serial.println(accZ);
  }

  // 자이로 읽기 (시작 레지스터 43H부터 6바이트 연속 읽기)
  Wire.beginTransmission(MPU6050_ADDR); // 슬레이브 주소 저장 및 버퍼 초기화
  Wire.write(0x43); // 버퍼에 시작 레지스터 주소(43H) 올림
  Wire.endTransmission(false); // STOP 없이 전송 → Repeated START 준비

  Wire.requestFrom(MPU6050_ADDR, 6); // 6바이트 읽기 요청
  if (Wire.available() == 6) {
    uint8_t gxMSB = Wire.read(); // 43H : 자이로 X MSB
    uint8_t gxLSB = Wire.read(); // 44H : 자이로 X LSB
    uint8_t gyMSB = Wire.read(); // 45H : 자이로 Y MSB
    uint8_t gyLSB = Wire.read(); // 46H : 자이로 Y LSB
    uint8_t gzMSB = Wire.read(); // 47H : 자이로 Z MSB
    uint8_t gzLSB = Wire.read(); // 48H : 자이로 Z LSB

    // MSB << 8 | LSB 로 16bit 값 조합
    gyroX = (int16_t)(gxMSB << 8 | gxLSB);
    gyroY = (int16_t)(gyMSB << 8 | gyLSB);
    gyroZ = (int16_t)(gzMSB << 8 | gzLSB);

    Serial.print("MPU6050 Gyro X: "); Serial.print(gyroX);
    Serial.print(" Y: "); Serial.print(gyroY);
    Serial.print(" Z: "); Serial.println(gyroZ);
  }
}


// Task 1 : HMC5883 지자기 센서 (Mutex 관리)
void task_hmc5883(void *pvParameters) {
  Serial.println("HMC5883 task started");

  for (;;) {
    if (xSemaphoreTake(i2cMutex, 0) == pdTRUE) {
      readHMC5883(); // HMC5883에서 X, Y, Z 읽기 및 Serial 출력
      xSemaphoreGive(i2cMutex);
    }

    Serial.println("HMC5883 task loop");
    vTaskDelay(100);
  }
}


// Task 2 : MPU6050 자이로+가속도 (Mutex 관리)
void task_mpu6050(void *pvParameters) {
  Serial.println("MPU6050 task started");

  for (;;) {
    if (xSemaphoreTake(i2cMutex, portMAX_DELAY) == pdTRUE) {
      readMPU6050(); // MPU6050에서 가속도/자이로 읽기 및 Serial 출력
      xSemaphoreGive(i2cMutex);
    }

    Serial.println("MPU6050 task loop");
    vTaskDelay(100);
  }
}


void setup() {
  Serial.begin(9600);
  Wire.begin();

  // 센서 초기화
  initHMC5883();
  initMPU6050();

  // Mutex 생성
  i2cMutex = xSemaphoreCreateMutex();

  if (i2cMutex != NULL) {
    xTaskCreate(task_hmc5883, "HMC5883 Task", 128, NULL, 2, &handle_hmc5883_task);
    xTaskCreate(task_mpu6050, "MPU6050 Task", 128, NULL, 2, &handle_mpu6050_task);
    vTaskStartScheduler();
  }

  Serial.println("Failed to start FreeRTOS scheduler");
  while(1);
}

void loop() {
  // FreeRTOS 사용할땐 loop 사용 안 함
}
